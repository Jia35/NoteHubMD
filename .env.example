# NoteHubMD Environment Configuration
# Copy this file to .env and modify as needed

# Application
APP_VERSION="0.0.1 beta"
APP_BASE_PATH="/"

# Server
PORT=3001

# Session (IMPORTANT: Change this in production!)
SESSION_SECRET="your-secret-key-here"

# Database
# For PostgreSQL (default):
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=notehubmd
DB_LOGGING=false

# For SQLite (alternative):
# DB_DIALECT=sqlite
# DB_STORAGE=./database/database.sqlite
# DB_LOGGING=false

# Default Permissions (private, auth-view, auth-edit, public-view, public-edit)
DEFAULT_NOTE_PERMISSION=private
DEFAULT_BOOK_PERMISSION=private

# Features
FEATURE_COMMENTS=true

# API Master Key (leave empty to disable)
API_MASTER_KEY=

# =====================
# LDAP / Active Directory
# =====================
# 啟用 LDAP 登入（設為 true 則只能用 AD 帳號登入，不開放註冊）
LDAP_ENABLED=false

# LDAP 伺服器 URL
LDAP_URL=ldap://your-ldap-server:389

# 管理員 DN（用於搜尋使用者）
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin-password

# 使用者搜尋設定
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
